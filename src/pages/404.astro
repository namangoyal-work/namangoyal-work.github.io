---
import Base from "../layouts/Base.astro";
---

<Base>
  <main class="nf">
    <div class="reveal is-in">
      <p class="nf__code">404</p>
      <h1 class="nf__title">This page wandered off.</h1>
      <p class="nf__msg">The link may be broken, or the page may have moved.</p>
      <a class="btn btn--primary" href="/">Back to home</a>
    </div>
  </main>
</Base>

<style>
  .nf { min-height: 100vh; display: grid; place-items: center; text-align: center; padding: 24px; }
  .nf__code {
    font-family: var(--font-display); font-weight: 700; line-height: 1;
    font-size: clamp(5rem, 20vw, 10rem); letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .nf__title { font-size: clamp(1.5rem, 4vw, 2.2rem); margin: 12px 0 8px; }
  .nf__msg { color: var(--text-muted); margin-bottom: 28px; }
</style>
