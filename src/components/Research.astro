---
import { research, activities } from "../data/research";
---

<section class="section section--alt" id="research">
  <div class="container">
    <header class="section__head reveal">
      <span class="eyebrow">02 — Research</span>
      <h2 class="section__title">Measuring whether open hardware is actually trustworthy.</h2>
    </header>

    <article class="card reveal">
      <div class="card__top">
        <div>
          <h3 class="card__title">{research.title}</h3>
          <p class="card__org">{research.org}</p>
        </div>
        <div class="card__meta">
          <span class="pill pill--accent">{research.role}</span>
          <span class="pill">{research.period}</span>
          {research.status && <span class="pill pill--soft">{research.status}</span>}
        </div>
      </div>

      <p class="card__summary">{research.summary}</p>

      <ul class="points">
        {research.points.map((p) => <li>{p}</li>)}
      </ul>

      <div class="chips">
        {research.tags.map((t) => <span class="chip">{t}</span>)}
      </div>
    </article>

    <div class="activities reveal">
      {activities.map((a) => (
        <div class="activity">
          <p class="activity__role">{a.role}</p>
          <p class="activity__org">{a.org}</p>
          <p class="activity__note">{a.note}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .card {
    position: relative; overflow: hidden;
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
    padding: clamp(24px, 4vw, 40px); box-shadow: var(--shadow-sm);
  }
  .card::before { content: ""; position: absolute; inset: 0 auto 0 0; width: 3px; background: linear-gradient(var(--accent), var(--accent-2)); }

  .card__top { display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap; margin-bottom: 22px; }
  .card__title { font-size: clamp(1.2rem, 2.6vw, 1.5rem); line-height: 1.25; margin-bottom: 8px; max-width: 30ch; }
  .card__org { font-size: 0.92rem; color: var(--text-muted); }
  .card__meta { display: flex; flex-wrap: wrap; gap: 8px; align-content: flex-start; }

  .pill {
    font-family: var(--font-mono); font-size: 0.74rem; padding: 5px 11px; border-radius: var(--radius-pill);
    border: 1px solid var(--border); color: var(--text-muted); white-space: nowrap;
  }
  .pill--accent { background: var(--accent); border-color: var(--accent); color: #fff; }
  .pill--soft { background: var(--accent-soft); border-color: transparent; color: var(--accent-ink); }

  .card__summary { font-size: 1.06rem; margin-bottom: 22px; max-width: 76ch; }
  .points { list-style: none; padding: 0; margin-bottom: 24px; display: grid; gap: 12px; }
  .points li { position: relative; padding-left: 26px; color: var(--text-muted); }
  .points li::before { content: ""; position: absolute; left: 4px; top: 9px; width: 7px; height: 7px; border: 1.5px solid var(--accent); border-radius: 50%; }

  .chips { display: flex; flex-wrap: wrap; gap: 8px; }

  .activities { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 24px; }
  .activity { padding: 22px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); }
  .activity__role { font-family: var(--font-display); font-weight: 600; margin-bottom: 4px; }
  .activity__org { color: var(--accent-ink); font-size: 0.9rem; margin-bottom: 8px; }
  .activity__note { color: var(--text-muted); font-size: 0.94rem; }

  @media (max-width: 720px) { .activities { grid-template-columns: 1fr; } }
</style>
