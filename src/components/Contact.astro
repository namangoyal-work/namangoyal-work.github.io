---
import { site } from "../data/site";

const methods = [
  { k: "LinkedIn", v: "in/namangoyalo", href: site.socials.linkedin },
  { k: "GitHub", v: "@namangoyal-work", href: site.socials.github },
  { k: "Résumé", v: "Download PDF", href: site.resume },
  { k: "Based in", v: site.location, href: null },
];
---

<section class="section" id="contact">
  <div class="container">
    <header class="section__head reveal">
      <span class="eyebrow">05 — Contact</span>
      <h2 class="section__title">Let's build something.</h2>
      <p class="section__lead">
        I'm open to quantitative, software, and hardware internships, and to research
        collaborations. The fastest way to reach me is email — I read everything.
      </p>
    </header>

    <div class="contact reveal">
      <a class="email" href={`mailto:${site.email}`} data-magnetic>
        <span class="email__label">Email me</span>
        <span class="email__addr">{site.email}</span>
        <svg class="email__arrow" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
      </a>

      <div class="methods">
        {methods.map((m) =>
          m.href ? (
            <a class="method" href={m.href} target={m.href.startsWith("http") ? "_blank" : undefined} rel="noopener">
              <span class="method__k">{m.k}</span>
              <span class="method__v">{m.v}</span>
            </a>
          ) : (
            <div class="method method--static">
              <span class="method__k">{m.k}</span>
              <span class="method__v">{m.v}</span>
            </div>
          ),
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .contact { display: grid; gap: 18px; }

  /* The email is the focal point of the closing section. */
  .email {
    position: relative; display: flex; flex-direction: column; gap: 6px;
    padding: 32px clamp(24px, 4vw, 40px);
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
    box-shadow: var(--shadow-sm); overflow: hidden;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .email::after {
    content: ""; position: absolute; inset: 0; border-radius: var(--radius); padding: 1px;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude; opacity: 0; transition: opacity 0.3s var(--ease);
  }
  .email:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
  .email:hover::after { opacity: 1; }
  .email__label { font-family: var(--font-mono); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-faint); }
  .email__addr { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.4rem, 4.5vw, 2.4rem); letter-spacing: -0.02em; word-break: break-word; }
  .email__arrow { position: absolute; top: 28px; right: 28px; color: var(--accent); transition: transform 0.3s var(--ease); }
  .email:hover .email__arrow { transform: translate(3px, -3px); }

  .methods { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  .method {
    display: flex; flex-direction: column; gap: 6px; padding: 20px;
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm);
    transition: transform 0.2s var(--ease), border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  a.method:hover { transform: translateY(-3px); border-color: var(--border-strong); color: var(--accent-ink); }
  .method__k { font-family: var(--font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-faint); }
  .method__v { font-size: 0.95rem; font-weight: 500; }

  @media (max-width: 760px) { .methods { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 420px) { .methods { grid-template-columns: 1fr; } }
</style>
